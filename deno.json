{
	"compilerOptions": {
		"lib": [
			"deno.ns",
			"deno",
			"dom"
		],
		"strict": true
	},
	"tasks": {
		"fmt": "deno fmt --watch *",
		"test:cli": "TESTING=true && deno test --allow-read --allow-write --allow-env --allow-run --allow-net --allow-sys --no-check"
	},
	"unstable": [
		"bare-node-builtins"
	],
	"imports": {
		"@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.0",
		"@cliffy/command": "jsr:@cliffy/command@^1.0.0",
		"@cliffy/keycode": "jsr:@cliffy/keycode@^1.0.0",
		"@cliffy/keypress": "jsr:@cliffy/keypress@^1.0.0",
		"@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
		"@cliffy/table": "jsr:@cliffy/table@^1.0.0",
		"@luxass/zod-error-utils": "jsr:@luxass/zod-error-utils@^0.3.0",
		"@opensrc/deno-open": "jsr:@opensrc/deno-open@^1.0.0",
		"@std/assert": "jsr:@std/assert@^1.0.19",
		"@std/cli": "jsr:@std/cli@^1.0.28",
		"@std/expect": "jsr:@std/expect@^1.0.18",
		"@std/io": "jsr:@std/io@^0.225.3",
		"@std/path": "jsr:@std/path@^1.1.4",
		"@std/semver": "jsr:@std/semver@^1.0.8",
		"@std/testing": "jsr:@std/testing@^1.0.17",
		"axios": "npm:axios@^1.15.0",
		"csv": "npm:csv@^6.5.1",
		"csv-stringify": "npm:csv-stringify@^6.7.0",
		"drivelist": "npm:drivelist@^12.0.2",
		"form-data": "npm:form-data@^4.0.5",
		"systeminformation": "npm:systeminformation@^5.31.5",
		"zod": "npm:zod@^3.25.76",
		"@webdock/sdk": "npm:@webdock/sdk@^1.1.109"
	},
	"fmt": {
		"lineWidth": 200,
		"useTabs": true,
		"indentWidth": 4,
		"semiColons": true
	}
}